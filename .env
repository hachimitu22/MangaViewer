NODE_ENV=production
PORT=3000
HOST=127.0.0.1
APP_ORIGIN=http://127.0.0.1:3000
APP_ALLOWED_HOSTS=127.0.0.1,localhost,::1

DATABASE_STORAGE_PATH=./var/data/mangaviewer.sqlite
CONTENT_ROOT_DIRECTORY=./public/contents

# 本番はハッシュ化済みの認証情報を設定してください
LOGIN_USER_ID=
LOGIN_USERNAME=
LOGIN_PASSWORD_HASH=
ALLOW_INSECURE_DEFAULT_LOGIN=
LOGIN_SESSION_TTL_MS=86400000

AUTH_STATE_STORE_BACKEND=memory
REDIS_URL=
REDIS_SESSION_KEY_PREFIX=session
REDIS_AUTH_KEY_PREFIX=auth
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_FAILURE_STATE_TTL_MS=86400000
AUTH_STORE_FAILURE_POLICY=fail_close

LOGIN_HASH_MEMORY_COST=65536
LOGIN_HASH_ITERATIONS=16384
LOGIN_HASH_PARALLELISM=1
LOGIN_HASH_TIME_COST=8

LOG_FILE_PATH=./var/logs/mangaviewer.log
LOG_LEVEL=INFO
LOG_OUTPUTS=console,file
