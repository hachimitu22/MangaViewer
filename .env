# NODE_ENV
# - 目的: 実行モードを指定します（production / development / test）。
# - 例: production
# - 組み合わせ: 本番起動は NODE_ENV=production + LOG_LEVEL=INFO + AUTH_STORE_FAILURE_POLICY=fail_close を推奨。
NODE_ENV=production

# PORT
# - 目的: HTTP サーバーの待受ポートを指定します。
# - 例: 3000
# - 組み合わせ: HOST とセットで公開範囲が決まる（例: HOST=127.0.0.1 + PORT=3000）。
PORT=3000

# HOST
# - 目的: HTTP サーバーのバインド先アドレスを指定します。
# - 例: 127.0.0.1
# - 組み合わせ: APP_ORIGIN / APP_ALLOWED_HOSTS と整合する値に設定する。
HOST=127.0.0.1

# APP_ORIGIN
# - 目的: アプリの正規オリジン（CSRF・URL生成の基準）を指定します。
# - 例: http://127.0.0.1:3000
# - 組み合わせ: HOST, PORT, APP_ALLOWED_HOSTS と同じ到達先になるように揃える。
APP_ORIGIN=http://127.0.0.1:3000

# APP_ALLOWED_HOSTS
# - 目的: 許可する Host ヘッダをカンマ区切りで指定します。
# - 例: 127.0.0.1,localhost,::1
# - 組み合わせ: APP_ORIGIN のホスト名を必ず含める。
APP_ALLOWED_HOSTS=127.0.0.1,localhost,::1

# DATABASE_STORAGE_PATH
# - 目的: SQLite DB ファイルパスを指定します。
# - 例: ./var/data/mangaviewer.sqlite
# - 組み合わせ: 環境ごとに別パスを使い、.env.dev/.env.test と共有しない。
DATABASE_STORAGE_PATH=./var/data/mangaviewer.sqlite

# CONTENT_ROOT_DIRECTORY
# - 目的: メディアコンテンツのルートディレクトリを指定します。
# - 例: ./public/contents
# - 組み合わせ: アプリ配信パスと実ファイル配置を一致させる。
CONTENT_ROOT_DIRECTORY=./public/contents

# 本番はハッシュ化済みの認証情報を設定してください
# LOGIN_USER_ID
# - 目的: ログイン利用者IDを指定します。
# - 例: admin-user-id
# - 組み合わせ: LOGIN_USERNAME / LOGIN_PASSWORD_HASH と同一ユーザー情報で揃える。
LOGIN_USER_ID=

# LOGIN_USERNAME
# - 目的: ログインユーザー名を指定します。
# - 例: admin
# - 組み合わせ: LOGIN_USER_ID / LOGIN_PASSWORD_HASH とセットで必須。
LOGIN_USERNAME=

# LOGIN_PASSWORD_HASH
# - 目的: パスワードのハッシュ値を指定します（平文不可）。
# - 例: scrypt$N=16384,r=8,p=1$...
# - 組み合わせ: LOGIN_HASH_* パラメータと整合する形式の値を使う。
LOGIN_PASSWORD_HASH=

# ALLOW_INSECURE_DEFAULT_LOGIN
# - 目的: 未設定時の insecure フォールバック許可フラグです（通常は空/false）。
# - 例: false
# - 組み合わせ: 本番では未設定または false を維持し、LOGIN_* を必ず設定する。
ALLOW_INSECURE_DEFAULT_LOGIN=

# LOGIN_SESSION_TTL_MS
# - 目的: ログインセッション有効期限（ミリ秒）を指定します。
# - 例: 86400000
# - 組み合わせ: REDIS セッション利用時も同等のTTL運用方針に揃える。
LOGIN_SESSION_TTL_MS=86400000

# AUTH_STATE_STORE_BACKEND
# - 目的: 認証状態ストアのバックエンド種別を指定します（memory / redis）。
# - 例: memory
# - 組み合わせ: redis を使う場合は REDIS_URL と接頭辞設定を併せて指定。
AUTH_STATE_STORE_BACKEND=memory

# REDIS_URL
# - 目的: Redis 接続先URLを指定します。
# - 例: redis://127.0.0.1:6379/0
# - 組み合わせ: AUTH_STATE_STORE_BACKEND=redis のとき必須。
REDIS_URL=

# REDIS_SESSION_KEY_PREFIX
# - 目的: Redis保存時のセッションキー接頭辞を指定します。
# - 例: session
# - 組み合わせ: 環境別に衝突しない接頭辞（例: prod:session）へ変更可能。
REDIS_SESSION_KEY_PREFIX=session

# REDIS_AUTH_KEY_PREFIX
# - 目的: Redis保存時の認証補助キー接頭辞を指定します。
# - 例: auth
# - 組み合わせ: REDIS_SESSION_KEY_PREFIX と同じ命名規則で管理する。
REDIS_AUTH_KEY_PREFIX=auth

# LOGIN_RATE_LIMIT_WINDOW_MS
# - 目的: ログイン試行回数のレート制限ウィンドウ（ミリ秒）を指定します。
# - 例: 60000
# - 組み合わせ: LOGIN_FAILURE_STATE_TTL_MS と合わせてロックアウト方針を決める。
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# LOGIN_FAILURE_STATE_TTL_MS
# - 目的: ログイン失敗状態の保持時間（ミリ秒）を指定します。
# - 例: 86400000
# - 組み合わせ: LOGIN_RATE_LIMIT_WINDOW_MS より長く設定し、総当たり耐性を担保する。
LOGIN_FAILURE_STATE_TTL_MS=86400000

# AUTH_STORE_FAILURE_POLICY
# - 目的: 認証ストア障害時の挙動（fail_close / fail_open）を指定します。
# - 例: fail_close
# - 組み合わせ: 本番は NODE_ENV=production と合わせて fail_close を推奨。
AUTH_STORE_FAILURE_POLICY=fail_close

# LOGIN_HASH_MEMORY_COST
# - 目的: scrypt 等のメモリコストパラメータを指定します。
# - 例: 65536
# - 組み合わせ: LOGIN_HASH_ITERATIONS / PARALLELISM / TIME_COST と同時調整する。
LOGIN_HASH_MEMORY_COST=65536

# LOGIN_HASH_ITERATIONS
# - 目的: ハッシュ計算の反復回数を指定します。
# - 例: 16384
# - 組み合わせ: ハッシュ再生成時は LOGIN_HASH_* を一式で同時更新する。
LOGIN_HASH_ITERATIONS=16384

# LOGIN_HASH_PARALLELISM
# - 目的: ハッシュ計算の並列度を指定します。
# - 例: 1
# - 組み合わせ: CPUリソースと TIME_COST を見ながら調整する。
LOGIN_HASH_PARALLELISM=1

# LOGIN_HASH_TIME_COST
# - 目的: ハッシュ計算の時間コストを指定します。
# - 例: 8
# - 組み合わせ: MEMORY_COST / ITERATIONS / PARALLELISM と整合する値に揃える。
LOGIN_HASH_TIME_COST=8

# LOG_FILE_PATH
# - 目的: ファイルログ出力先パスを指定します。
# - 例: ./var/logs/mangaviewer.log
# - 組み合わせ: LOG_OUTPUTS に file を含む場合は書き込み可能パスを指定。
LOG_FILE_PATH=./var/logs/mangaviewer.log

# LOG_LEVEL
# - 目的: 出力ログレベルを指定します。
# - 例: INFO
# - 組み合わせ: LOG_OUTPUTS と併用し、production は INFO 以上を推奨。
LOG_LEVEL=INFO

# LOG_OUTPUTS
# - 目的: ログ出力先をカンマ区切りで指定します（console,file,memory）。
# - 例: console,file
# - 組み合わせ: file を使うなら LOG_FILE_PATH、memory を使うなら test 実行時用途で利用する。
LOG_OUTPUTS=console,file
